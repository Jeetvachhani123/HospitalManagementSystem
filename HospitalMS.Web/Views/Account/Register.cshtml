@model HospitalMS.Web.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account - Hospital Management System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 0;
        }

        .register-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.06);
            overflow: hidden;
            width: 100%;
            max-width: 600px;
            background: #fff;
        }

        .register-header {
            padding: 2rem 2rem 1rem;
            text-align: center;
        }

        .register-body {
            padding: 2rem;
        }

        .form-control, .form-select {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-size: 0.95rem;
            background-color: #f9f9f9;
            border: 1px solid #e9ecef;
        }

            .form-control:focus, .form-select:focus {
                background-color: #fff;
                border-color: #0d6efd;
                box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.1);
            }

        .btn-primary {
            padding: 0.8rem 1rem;
            border-radius: 8px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }
    </style>
</head>
<body>
    <div class="register-card">
        <div class="register-header">
            <h4 class="fw-bold mb-1">Create Account</h4>
            <p class="text-muted small">Join Hospital Management System</p>
        </div>
        <div class="register-body pt-0">
            <form asp-action="Register" method="post" id="registerForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-4 border-0 bg-danger-subtle text-danger rounded-3"></div>
                <input type="hidden" asp-for="Role" value="Patient" />
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label small fw-bold text-muted text-uppercase">First Name</label>
                        <input asp-for="FirstName" class="form-control" placeholder="FirstName" />
                        <span asp-validation-for="FirstName" class="text-danger small mt-1 d-block"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label small fw-bold text-muted text-uppercase">Last Name</label>
                        <input asp-for="LastName" class="form-control" placeholder="LastName" />
                        <span asp-validation-for="LastName" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="DateOfBirth" class="form-label small fw-bold text-muted text-uppercase">Date of Birth</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                        <span asp-validation-for="DateOfBirth" class="text-danger small mt-1 d-block"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Gender" class="form-label small fw-bold text-muted text-uppercase">Gender</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="">Select Gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label small fw-bold text-muted text-uppercase">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="+1234567890" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BloodGroup" class="form-label small fw-bold text-muted text-uppercase">Blood Group</label>
                        <select asp-for="BloodGroup" class="form-select">
                            <option value="">Select Blood Group</option>
                            <option value="A+">A+</option>
                            <option value="A-">A-</option>
                            <option value="B+">B+</option>
                            <option value="B-">B-</option>
                            <option value="AB+">AB+</option>
                            <option value="AB-">AB-</option>
                            <option value="O+">O+</option>
                            <option value="O-">O-</option>
                        </select>
                        <span asp-validation-for="BloodGroup" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label small fw-bold text-muted text-uppercase">Email Address</label>
                    <input asp-for="Email" class="form-control" placeholder="name@company.com" />
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label small fw-bold text-muted text-uppercase">Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Create password" />
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label small fw-bold text-muted text-uppercase">Confirm</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary shadow-sm" id="submitBtn">
                        <span id="btnText">Create Account</span>
                        <span id="btnSpinner" class="spinner-border spinner-border-sm ms-2" role="status" aria-hidden="true" style="display:none;"></span>
                    </button>
                    <a asp-action="Login" class="btn btn-light text-muted">Already have an account? Sign In</a>
                </div>
            </form>
        </div>
        <div class="bg-light py-3 text-center border-top">
            <small class="text-muted">By signing up, you agree to our Terms & Privacy Policy.</small>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#registerForm').on('submit', function() {
                if($(this).valid()) {
                    $('#submitBtn').prop('disabled', true);
                    $('#btnText').text('Creating Account...');
                    $('#btnSpinner').show();
                }
            });
        });
    </script>
</body>
</html>