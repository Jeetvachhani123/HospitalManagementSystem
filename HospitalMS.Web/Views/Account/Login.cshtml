@model HospitalMS.BL.DTOs.Auth.LoginDto
@{
    ViewData["Title"] = "Log in";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hospital MS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="text-center mb-4">
                    <a href="/" class="text-decoration-none">
                        <i class="bi bi-hospital-fill text-primary display-4"></i>
                        <h2 class="fw-bold text-dark mt-2">Hospital MS</h2>
                    </a>
                    <p class="text-secondary">Sign in to your account</p>
                </div>
                
                <div class="card border-0 shadow-sm bg-white" style="border-radius: 1rem;">
                    <div class="card-body p-4 p-md-5">
                        <form id="account" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                            
                            <div class="mb-4">
                                <label asp-for="Email" class="form-label text-dark fw-bold">Email Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted">
                                        <i class="bi bi-envelope"></i>
                                    </span>
                                    <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="name@example.com" autocomplete="username" aria-required="true" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                            </div>
                            
                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <label asp-for="Password" class="form-label text-dark fw-bold mb-0">Password</label>
                                    <a class="small text-primary text-decoration-none fw-medium" asp-action="ForgotPassword">Forgot password?</a>
                                </div>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted">
                                        <i class="bi bi-lock"></i>
                                    </span>
                                    <input asp-for="Password" class="form-control border-start-0 ps-0" placeholder="••••••••" autocomplete="current-password" aria-required="true" />
                                </div>
                                <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                            </div>
                            
                            <button id="login-submit" type="submit" class="btn btn-primary w-100 py-2 fw-bold mb-4">
                                Sign In
                            </button>
                            
                            <div class="text-center">
                                <span class="text-secondary small">Don't have an account?</span>
                                <a asp-action="Register" class="text-primary text-decoration-none small fw-bold ms-1">Register now</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>