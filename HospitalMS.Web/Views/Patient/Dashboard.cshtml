@model HospitalMS.Web.ViewModels.PatientDashboardViewModel
@{
    ViewData["Title"] = "Patient Dashboard";
}
<div class="container py-5">
    <div class="row mb-5 align-items-center">
        <div class="col-lg-8">
            <h1 class="h2 fw-bold text-gray-800">Hello, @Model.Patient.FullName</h1>
            <p class="text-muted lead mb-0">Welcome back to your health dashboard.</p>
        </div>
        <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
            <a asp-controller="Doctor" asp-action="Index" class="btn btn-primary btn-lg px-5 shadow-sm rounded-pill fw-bold">
                <i class="bi bi-calendar-plus me-2"></i>Book Appointment
            </a>
        </div>
    </div>
    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-white dashboard-card"
                 data-type="Upcoming" style="cursor:pointer;">
                <div class="card-body p-4 text-center">
                    <div class="icon-circle bg-primary bg-opacity-10 text-primary rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width:50px;height:50px;">
                        <i class="bi bi-calendar-event fs-4"></i>
                    </div>
                    <h6 class="text-muted text-uppercase small fw-bold">Upcoming</h6>
                    <h2 class="fw-bold mb-0">@Model.UpcomingAppointmentsCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-white dashboard-card"
                 data-type="Pending" style="cursor:pointer;">
                <div class="card-body p-4 text-center">
                    <div class="icon-circle bg-warning bg-opacity-10 text-warning rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width:50px;height:50px;">
                        <i class="bi bi-hourglass-split fs-4"></i>
                    </div>
                    <h6 class="text-muted text-uppercase small fw-bold">Pending</h6>
                    <h2 class="fw-bold mb-0">@Model.PendingApprovalsCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-white dashboard-card"
                 data-type="Completed" style="cursor:pointer;">
                <div class="card-body p-4 text-center">
                    <div class="icon-circle bg-success bg-opacity-10 text-success rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width:50px;height:50px;">
                        <i class="bi bi-check-circle fs-4"></i>
                    </div>
                    <h6 class="text-muted text-uppercase small fw-bold">Completed</h6>
                    <h2 class="fw-bold mb-0">@Model.CompletedAppointmentsCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-white dashboard-card"
                 data-type="Cancelled" style="cursor:pointer;">
                <div class="card-body p-4 text-center">
                    <div class="icon-circle bg-danger bg-opacity-10 text-danger rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width:50px;height:50px;">
                        <i class="bi bi-x-circle fs-4"></i>
                    </div>
                    <h6 class="text-muted text-uppercase small fw-bold">Cancelled</h6>
                    <h2 class="fw-bold mb-0">@Model.CancelledAppointmentsCount</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-bottom d-flex align-items-center justify-content-between">
                    <h5 class="fw-bold text-dark m-0">Upcoming Schedule</h5>
                    <a asp-controller="Appointment" asp-action="Index" class="small text-decoration-none fw-bold">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @if (Model.RecentAppointments != null && Model.RecentAppointments.Any(a => a.AppointmentDate.Date >= DateTime.Today && a.Status != "Completed" && a.Status != "Cancelled" && a.Status != "NoShow" && a.ApprovalStatus != "Rejected"))
                        {
                            foreach (var appt in Model.RecentAppointments.Where(a => a.AppointmentDate.Date >= DateTime.Today && a.Status != "Completed" && a.Status != "Cancelled" && a.Status != "NoShow" && a.ApprovalStatus != "Rejected").OrderBy(a => a.AppointmentDate).Take(3))
                            {
                                <div class="list-group-item p-4 border-bottom">
                                    <div class="d-flex w-100 justify-content-between align-items-center">
                                        <div class="d-flex align-items-center">
                                            <div class="date-box bg-light border rounded text-center me-3 p-2" style="min-width: 60px;">
                                                <span class="d-block text-uppercase small fw-bold text-muted">@appt.AppointmentDate.ToString("MMM")</span>
                                                <span class="d-block h4 fw-bold mb-0 text-primary">@appt.AppointmentDate.Day</span>
                                            </div>
                                            <div>
                                                <h6 class="mb-1 fw-bold text-dark">Dr. @appt.DoctorName</h6>
                                                <p class="mb-0 small text-muted">@appt.Specialization</p>
                                                <span class="badge bg-light text-secondary mt-2">
                                                    <i class="bi bi-clock me-1"></i> @DateTime.Today.Add(appt.StartTime).ToString("hh:mm tt")
                                                </span>
                                            </div>
                                        </div>
                                        <div>
                                            <a asp-controller="Appointment" asp-action="Details" asp-route-id="@appt.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">Details</a>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <div class="mb-3">
                                    <i class="bi bi-calendar-x text-muted opacity-50 display-4"></i>
                                </div>
                                <h6 class="text-muted fw-bold">No Upcoming Appointments</h6>
                                <p class="text-muted small mb-3">You have no scheduled visits at the moment.</p>
                                <a asp-controller="Doctor" asp-action="Index" class="btn btn-sm btn-primary rounded-pill px-4">Book Now</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="fw-bold text-dark m-0">Recent History</h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.RecentAppointments != null && Model.RecentAppointments.Any(a => a.AppointmentDate.Date < DateTime.Today || a.Status == "Completed" || a.Status == "Cancelled" || a.Status == "NoShow" || a.ApprovalStatus == "Rejected"))
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var appt in Model.RecentAppointments.Where(a => a.AppointmentDate.Date < DateTime.Today || a.Status == "Completed" || a.Status == "Cancelled" || a.Status == "NoShow" || a.ApprovalStatus == "Rejected").OrderByDescending(a => a.AppointmentDate).Take(5))
                            {
                                <li class="list-group-item px-4 py-3 border-bottom">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <small class="text-muted d-block mb-1">@appt.AppointmentDate.ToString("MMM dd, yyyy")</small>
                                            <span class="fw-bold text-dark d-block">Dr. @appt.DoctorName</span>
                                            <span class="small text-muted">@appt.Specialization</span>
                                        </div>
                                        <span class="badge bg-light text-secondary border">@appt.Status</span>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted small">
                            No past appointments found.
                        </div>
                    }
                </div>
                <div class="card-footer bg-white border-0 text-center py-3">
                    <a asp-controller="Appointment" asp-action="History" class="text-decoration-none fw-bold small">View Full History</a>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="appointmentModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Appointment Details</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="appointmentDetailsContent">
                        Loading...
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.querySelectorAll('.dashboard-card').forEach(card => {
            card.addEventListener('click', function () {
                const type = this.getAttribute('data-type');
                fetch(`/Appointment/GetByStatusPopup?status=${type}`)
                    .then(response => response.json())
                    .then(data => {
                        let html = "";
                        if (data.length === 0) {
                            html = `
                                <div class="text-center py-4">
                                    <i class="bi bi-calendar-x fs-1 text-muted"></i>
                                    <p class="mt-3 text-muted">No appointments found.</p>
                                </div>`;
                        } else {
                            data.forEach(appt => {
                                html += `
                                    <div class="card mb-3 border-0 shadow-sm rounded-3">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <h6 class="fw-bold mb-1">Dr. ${appt.doctorName}</h6>
                                                    <small class="text-muted">
                                                        <i class="bi bi-calendar me-1"></i> ${appt.date}
                                                        &nbsp; | &nbsp;
                                                        <i class="bi bi-clock me-1"></i> ${appt.time}
                                                    </small>
                                                </div>
                                                <span class="badge bg-primary">${appt.status}</span>
                                            </div>
                                        </div>
                                    </div>`;
                            });
                        }
                        document.getElementById('appointmentDetailsContent').innerHTML = html;
                        var modal = new bootstrap.Modal(document.getElementById('appointmentModal'));
                        modal.show();
                    })
                    .catch(error => {
                        document.getElementById('appointmentDetailsContent').innerHTML =
                            "<div class='text-danger text-center py-4'>Failed to load data.</div>";
                    });
            });
        });
    </script>
}