@model HospitalMS.Web.ViewModels.PatientEditViewModel
@{
    ViewData["Title"] = "Edit Patient Profile";
}
<div class="container py-5">
    <div class="row mb-5 justify-content-center">
        <div class="col-lg-8 text-center text-lg-start">
            <h2 class="display-6 fw-bold text-gray-800">Medical Profile</h2>
            <p class="text-muted lead mb-0">Update your personal and medical information for better care.</p>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary bg-opacity-10 py-3 border-bottom-0">
                    <div class="d-flex align-items-center">
                        <div class="avatar-circle bg-white text-primary rounded-circle me-3 fw-bold d-flex align-items-center justify-content-center border" style="width: 48px; height: 48px; font-size: 1.25rem;">
                            <i class="bi bi-person-heart"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-primary mb-0">Patient Details</h5>
                            <small class="text-muted">Ensure this information is up-to-date.</small>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4 bg-white">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="FullName" />
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="DateOfBirth" />
                        @if (ViewData.ModelState.ErrorCount > 0)
                        {
                            <div class="alert alert-danger border-0 shadow-sm mb-4">
                                <ul class="mb-0 ps-3">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small text-uppercase">Full Name</label>
                                <input type="text" class="form-control bg-light" value="@Model.FullName" readonly disabled />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small text-uppercase">Email</label>
                                <input type="text" class="form-control bg-light" value="@Model.Email" readonly disabled />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small text-uppercase">Date of Birth</label>
                                <input type="text" class="form-control bg-light" value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" readonly disabled />
                            </div>
                        </div>
                        <hr class="my-4 opacity-25" />
                        <h6 class="fw-bold text-dark mb-4"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Contact Information</h6>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label fw-bold text-muted small text-uppercase">Phone Number</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-telephone"></i></span>
                                    <input asp-for="PhoneNumber" class="form-control border-start-0 bg-light-subtle" placeholder="+1 (555) 000-0000" />
                                </div>
                                <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EmergencyContact" class="form-label fw-bold text-muted small text-uppercase">Emergency Contact</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-telephone-plus"></i></span>
                                    <input asp-for="EmergencyContact" class="form-control border-start-0 bg-light-subtle" placeholder="Name & Number" />
                                </div>
                                <span asp-validation-for="EmergencyContact" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <hr class="my-4 opacity-25" />
                        <h6 class="fw-bold text-dark mb-4"><i class="bi bi-bandaid me-2 text-danger"></i>Medical Details</h6>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label asp-for="BloodGroup" class="form-label fw-bold text-muted small text-uppercase">Blood Group</label>
                                <select asp-for="BloodGroup" class="form-select bg-light-subtle">
                                    <option value="">Select Group</option>
                                    <option value="A+">A+</option>
                                    <option value="A-">A-</option>
                                    <option value="B+">B+</option>
                                    <option value="B-">B-</option>
                                    <option value="AB+">AB+</option>
                                    <option value="AB-">AB-</option>
                                    <option value="O+">O+</option>
                                    <option value="O-">O-</option>
                                </select>
                                <span asp-validation-for="BloodGroup" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Gender" class="form-label fw-bold text-muted small text-uppercase">Gender</label>
                                <select asp-for="Gender" class="form-select bg-light-subtle">
                                    <option value="">Select Gender</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="MedicalHistory" class="form-label fw-bold text-muted small text-uppercase">Medical History</label>
                                <textarea asp-for="MedicalHistory" class="form-control bg-light-subtle" rows="3" placeholder="Any past surgeries, chronic conditions, or major illnesses..."></textarea>
                                <span asp-validation-for="MedicalHistory" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Allergies" class="form-label fw-bold text-muted small text-uppercase">Allergies</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-warning bg-opacity-10 border-warning border-opacity-25 text-warning"><i class="bi bi-exclamation-triangle-fill"></i></span>
                                    <textarea asp-for="Allergies" class="form-control bg-light-subtle border-start-0" rows="2" placeholder="List any allergies to medications, food, environment..."></textarea>
                                </div>
                                <span asp-validation-for="Allergies" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <hr class="my-5 opacity-25" />
                        <div class="d-flex justify-content-end gap-3 align-items-center">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Index" class="btn btn-light rounded-pill px-4 fw-bold text-muted">Cancel</a>
                            }
                            else
                            {
                                <a asp-controller="Patient" asp-action="Dashboard" class="btn btn-light rounded-pill px-4 fw-bold text-muted">Cancel</a>
                            }
                            <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm hover-lift transition-all">
                                <i class="bi bi-check-lg me-2"></i> Save Profile
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}