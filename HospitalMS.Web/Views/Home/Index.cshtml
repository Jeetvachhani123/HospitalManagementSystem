@{
    ViewData["Title"] = "Modern Healthcare";
    bool isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<div class="position-relative overflow-hidden bg-mesh" style="min-height: 85vh;">
    <!-- Decorative background elements -->
    <div class="position-absolute top-0 start-0 w-100 h-100 overflow-hidden z-0 pointer-events-none">
        <div class="position-absolute top-0 start-0 translate-middle bg-primary opacity-10 rounded-circle" style="width: 800px; height: 800px; filter: blur(80px);"></div>
        <div class="position-absolute bottom-0 end-0 translate-middle-y bg-secondary opacity-10 rounded-circle" style="width: 600px; height: 600px; filter: blur(60px);"></div>
    </div>

    <div class="container position-relative z-1 py-5">
        <div class="row min-vh-75 align-items-center py-5">
            <div class="col-lg-6 py-5 animate-fade-in-up">
                <div class="pe-lg-5">
                    <span class="badge bg-primary px-3 py-2 mb-4 d-inline-flex align-items-center">
                        <i class="bi bi-stars me-2 fs-6"></i> <span class="fs-6">Next-Gen Healthcare Platform</span>
                    </span>
                    <h1 class="display-3 fw-bold lh-tight mb-4 text-dark" style="letter-spacing: -0.04em;">
                        Healthcare <br />
                        <span class="text-gradient">Reimagined</span> <br />
                        for everyone.
                    </h1>
                    <p class="lead text-secondary mb-5 pe-lg-4 fs-4" style="font-weight: 400;">
                        Experience seamless patient care, efficient scheduling, and secure medical records. Connecting doctors and patients with technology that cares.
                    </p>
                    <div class="d-flex flex-column flex-sm-row gap-3">
                        @if (!isAuthenticated)
                        {
                            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow-lg hover-lift d-inline-flex align-items-center justify-content-center">
                                Get Started Free <i class="bi bi-arrow-right ms-2"></i>
                            </a>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-lg rounded-pill px-5 py-3 hover-lift glass-panel d-inline-flex align-items-center justify-content-center">
                                Sign In
                            </a>
                        }
                        else
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow-lg hover-lift">
                                    <i class="bi bi-grid-fill me-2"></i> Go to Dashboard
                                </a>
                            }
                            else if (User.IsInRole("Doctor"))
                            {
                                <a asp-controller="Doctor" asp-action="Dashboard" class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow-lg hover-lift">
                                    <i class="bi bi-calendar-check-fill me-2"></i> My Practice
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Patient" asp-action="Dashboard" class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow-lg hover-lift">
                                    <i class="bi bi-person-fill me-2"></i> My Health Portal
                                </a>
                            }
                        }
                    </div>
                    
                    <div class="mt-5 pt-3 d-flex align-items-center text-muted border-top border-opacity-10 border-dark">
                        <div class="d-flex me-3">
                            <div class="avatar-circle border border-2 border-white" style="width: 40px; height: 40px; margin-right: -12px; z-index: 3; font-size: 14px;">DR</div>
                            <div class="avatar-circle border border-2 border-white bg-success" style="width: 40px; height: 40px; margin-right: -12px; z-index: 2; font-size: 14px;">PT</div>
                            <div class="avatar-circle border border-2 border-white bg-info" style="width: 40px; height: 40px; z-index: 1; font-size: 14px;">NR</div>
                        </div>
                        <span class="fw-medium">Trusted by <strong class="text-dark">500+</strong> healthcare professionals</span>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6 d-none d-lg-block position-relative animate-fade-in-up" style="animation-delay: 0.2s;">
                <div class="position-absolute top-50 start-50 translate-middle w-100">
                    <!-- Glassmorphic floating card -->
                    <div class="card glass-panel border-0 rounded-2xl overflow-hidden mb-4 animate-float" style="transform-style: preserve-3d; border-radius: 1.5rem;">
                        <div class="card-header border-bottom border-opacity-10 py-3 px-4 d-flex justify-content-between align-items-center bg-white bg-opacity-50">
                            <div class="d-flex align-items-center">
                                <div class="spinner-grow spinner-grow-sm text-success me-2" role="status"></div>
                                <span class="fw-bold small text-uppercase text-muted">Live Status</span>
                            </div>
                            <i class="bi bi-three-dots text-muted"></i>
                        </div>
                        <div class="card-body p-4 text-start bg-white bg-opacity-75">
                            <div class="d-flex align-items-center mb-4">
                                <div class="bg-primary-light p-3 rounded-circle me-3">
                                    <i class="bi bi-calendar-check text-primary fs-3"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-1 text-dark">Upcoming Appointment</h5>
                                    <span class="text-secondary fw-medium">Dr. Sarah Jenkins - Cardiology</span>
                                </div>
                                <span class="ms-auto badge bg-primary px-3 py-2">Today, 10:00 AM</span>
                            </div>
                            <div class="progress rounded-pill bg-light" style="height: 8px;">
                                <div class="progress-bar bg-primary rounded-pill w-75" role="progressbar"></div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Decorative smaller card -->
                    <div class="card glass-panel border-0 rounded-xl overflow-hidden position-absolute bottom-0 end-0 translate-middle-y animate-float" style="width: 220px; right: -20px !important; animation-delay: 1.5s; border-radius: 1rem;">
                        <div class="card-body p-3 d-flex align-items-center gap-3">
                            <div class="bg-success bg-opacity-10 p-2 rounded-circle text-success">
                                <i class="bi bi-check-circle-fill fs-4"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0 text-dark">Verified</h6>
                                <small class="text-muted">Doctors</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="py-5 bg-white position-relative">
    <div class="container py-5">
        <div class="text-center mb-5 mx-auto" style="max-width: 700px;">
            <span class="badge bg-primary-light text-primary px-4 py-2 mb-3 fw-bold rounded-pill text-uppercase" style="letter-spacing: 1.5px;">Why Choose Us</span>
            <h2 class="display-6 fw-bold mt-2 text-dark">Comprehensive Features <br/> for modern needs</h2>
            <p class="text-secondary lead mt-3">Everything you need to manage your specialized medical practice or personal health journey in one beautiful platform.</p>
        </div>
        
        <div class="row g-4 pt-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 hover-lift bg-light rounded-2xl" style="border-radius: 1.5rem;">
                    <div class="card-body text-center p-2">
                        <div class="mb-4 bg-white text-primary rounded-circle d-inline-flex p-4 shadow-sm mx-auto">
                            <i class="bi bi-calendar-range fs-1"></i>
                        </div>
                        <h4 class="fw-bold mb-3 text-dark">Smart Scheduling</h4>
                        <p class="text-secondary mb-0">Book appointments instantly, manage availability, and reduce no-shows with automated reminders.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 hover-lift bg-light rounded-2xl" style="border-radius: 1.5rem;">
                    <div class="card-body text-center p-2">
                        <div class="mb-4 bg-white text-success rounded-circle d-inline-flex p-4 shadow-sm mx-auto">
                            <i class="bi bi-file-earmark-medical fs-1"></i>
                        </div>
                        <h4 class="fw-bold mb-3 text-dark">Digital Records</h4>
                        <p class="text-secondary mb-0">Access complete medical histories, lab results, and prescriptions securely from anywhere.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 hover-lift bg-light rounded-2xl" style="border-radius: 1.5rem;">
                    <div class="card-body text-center p-2">
                        <div class="mb-4 bg-white text-info rounded-circle d-inline-flex p-4 shadow-sm mx-auto">
                            <i class="bi bi-credit-card-2-front fs-1"></i>
                        </div>
                        <h4 class="fw-bold mb-3 text-dark">Seamless Billing</h4>
                        <p class="text-secondary mb-0">Transparent invoicing and secure payment processing with detailed financial reporting.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-gradient-primary text-white py-5 position-relative overflow-hidden">
    <div class="position-absolute top-0 start-0 w-100 h-100 bg-mesh opacity-25"></div>
    <div class="container py-5 text-center position-relative z-1">
        <h2 class="display-5 fw-bold mb-4">Ready to transform your healthcare experience?</h2>
        <p class="lead text-white-50 mb-5 mx-auto fs-4" style="max-width: 600px;">Join thousands of doctors and patients already using our platform for better outcomes.</p>
        @if (!isAuthenticated)
        {
            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg rounded-pill px-5 py-3 fw-bold shadow-lg text-primary hover-lift fs-5 d-inline-flex align-items-center">
                Get Started Now <i class="bi bi-arrow-right ms-2"></i>
            </a>
        }
    </div>
</div>