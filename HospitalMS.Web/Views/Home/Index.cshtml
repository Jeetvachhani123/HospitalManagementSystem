@{
    ViewData["Title"] = "Modern Healthcare";
    bool isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<div class="bg-light" style="min-height: 85vh; padding-top: 5rem;">
    <div class="container py-5">
        <div class="row align-items-center py-5">
            <div class="col-lg-6 py-5">
                <div class="pe-lg-5">
                    <span class="badge bg-primary px-3 py-2 mb-4 d-inline-flex align-items-center text-uppercase" style="letter-spacing: 1px;">
                        <i class="bi bi-shield-check me-2 fs-6"></i> Trusted Healthcare
                    </span>
                    <h1 class="display-4 fw-bold lh-tight mb-4 text-dark">
                        Excellence in <br />
                        <span class="text-primary">Medical Care</span> <br />
                        for your family.
                    </h1>
                    <p class="lead text-secondary mb-5 pe-lg-4 fs-5">
                        Experience seamless patient care, efficient scheduling, and secure medical records. A professional platform connecting top doctors with patients.
                    </p>
                    <div class="d-flex flex-column flex-sm-row gap-3">
                        @if (!isAuthenticated)
                        {
                            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg px-5 py-3 shadow-sm d-inline-flex align-items-center justify-content-center">
                                Register as Patient <i class="bi bi-arrow-right ms-2"></i>
                            </a>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-lg px-5 py-3 d-inline-flex align-items-center justify-content-center bg-white">
                                Staff Login
                            </a>
                        }
                        else
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-primary btn-lg px-5 py-3 shadow-sm">
                                    <i class="bi bi-speedometer2 me-2"></i> Admin Dashboard
                                </a>
                            }
                            else if (User.IsInRole("Doctor"))
                            {
                                <a asp-controller="Doctor" asp-action="Dashboard" class="btn btn-primary btn-lg px-5 py-3 shadow-sm">
                                    <i class="bi bi-calendar-check-fill me-2"></i> Doctor Portal
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Patient" asp-action="Dashboard" class="btn btn-primary btn-lg px-5 py-3 shadow-sm">
                                    <i class="bi bi-person-fill me-2"></i> Patient Portal
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6 d-none d-lg-block position-relative">
                <div class="position-absolute top-50 start-50 translate-middle w-100 ps-5">
                    <!-- Clean White Card -->
                    <div class="card border-0 shadow-md mb-4 bg-white" style="border-radius: 1rem;">
                        <div class="card-body p-4 p-xl-5">
                            <div class="d-flex align-items-center mb-4">
                                <div class="bg-primary-light p-3 rounded-circle me-4">
                                    <i class="bi bi-heart-pulse text-primary fs-2"></i>
                                </div>
                                <div>
                                    <h4 class="fw-bold mb-1 text-dark">Expert Physicians</h4>
                                    <span class="text-secondary fw-medium fs-6">Over 50+ specialists available</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center mb-4">
                                <div class="p-3 rounded-circle me-4" style="background-color: var(--brand-success-light);">
                                    <i class="bi bi-clipboard2-pulse text-success fs-2"></i>
                                </div>
                                <div>
                                    <h4 class="fw-bold mb-1 text-dark">Digital Records</h4>
                                    <span class="text-secondary fw-medium fs-6">100% secure & private health tracking</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center">
                                <div class="p-3 rounded-circle me-4" style="background-color: #E0F2FE;">
                                    <i class="bi bi-calendar-check fs-2" style="color: var(--brand-secondary);"></i>
                                </div>
                                <div>
                                    <h4 class="fw-bold mb-1 text-dark">Easy Scheduling</h4>
                                    <span class="text-secondary fw-medium fs-6">Book appointments in seconds</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="py-5 bg-white border-top border-bottom" style="border-color: var(--border-color) !important;">
    <div class="container py-5">
        <div class="text-center mb-5 mx-auto" style="max-width: 700px;">
            <h2 class="display-6 fw-bold text-dark">Comprehensive Services</h2>
            <p class="text-secondary lead mt-3">Professional tools for doctors, administrators, and seamless experiences for patients.</p>
        </div>
        
        <div class="row g-4 pt-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 shadow-sm bg-white hover-lift">
                    <div class="card-body text-center p-2">
                        <div class="mb-4 text-primary">
                            <i class="bi bi-calendar-range display-4"></i>
                        </div>
                        <h4 class="fw-bold mb-3 text-dark">Smart Scheduling</h4>
                        <p class="text-secondary mb-0">Book appointments instantly, manage availability, and reduce no-shows with automated reminders.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 shadow-sm bg-white hover-lift">
                    <div class="card-body text-center p-2">
                        <div class="mb-4 text-success">
                            <i class="bi bi-file-earmark-medical display-4"></i>
                        </div>
                        <h4 class="fw-bold mb-3 text-dark">Digital Records</h4>
                        <p class="text-secondary mb-0">Access complete medical histories, lab results, and prescriptions securely from anywhere.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 shadow-sm bg-white hover-lift">
                    <div class="card-body text-center p-2">
                        <div class="mb-4" style="color: var(--brand-secondary);">
                            <i class="bi bi-credit-card-2-front display-4"></i>
                        </div>
                        <h4 class="fw-bold mb-3 text-dark">Seamless Billing</h4>
                        <p class="text-secondary mb-0">Transparent invoicing and secure payment processing with detailed financial reporting.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-primary text-white py-5">
    <div class="container py-5 text-center">
        <h2 class="display-5 fw-bold mb-4">Ready to start?</h2>
        <p class="lead text-white-50 mb-5 mx-auto fs-5" style="max-width: 600px;">Join thousands of doctors and patients already using our professional platform.</p>
        @if (!isAuthenticated)
        {
            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg px-5 py-3 fw-bold text-primary shadow-sm">
                Get Started Now
            </a>
        }
    </div>
</div>