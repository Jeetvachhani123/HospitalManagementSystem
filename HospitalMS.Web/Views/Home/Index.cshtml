@{
    ViewData["Title"] = "Modern Healthcare";
    bool isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<!-- ═══ HERO SECTION ═══ -->
<div class="hero-gradient text-white" style="min-height: 90vh; padding-top: 5rem;">
    <div class="container py-5 position-relative" style="z-index:1;">
        <div class="row align-items-center py-5">
            <div class="col-lg-6 py-5 animate-fade-in-up">
                <div class="pe-lg-5">
                    <span class="badge bg-white bg-opacity-10 border border-white border-opacity-25 px-3 py-2 mb-4 d-inline-flex align-items-center text-uppercase text-white" style="letter-spacing: 1px; backdrop-filter: blur(10px);">
                        <i class="bi bi-shield-check me-2 fs-6"></i> Trusted Healthcare Platform
                    </span>
                    <h1 class="display-3 fw-bold lh-tight mb-4" style="letter-spacing:-0.03em;">
                        Excellence in <br />
                        <span style="background: linear-gradient(135deg, #60a5fa, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Medical Care</span> <br />
                        for your family.
                    </h1>
                    <p class="lead mb-5 pe-lg-4 fs-5" style="color: rgba(255,255,255,0.7);">
                        Experience seamless patient care, efficient scheduling, and secure medical records — all powered by a professional platform connecting top doctors with patients.
                    </p>
                    <div class="d-flex flex-column flex-sm-row gap-3 mb-5">
                        @if (!isAuthenticated)
                        {
                            <a asp-controller="Account" asp-action="Register" class="btn btn-lg px-5 py-3 fw-bold d-inline-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, #3b82f6, #8b5cf6); border:none; color:white; border-radius:50px; box-shadow: 0 8px 30px rgba(59,130,246,0.4);">
                                Register as Patient <i class="bi bi-arrow-right ms-2"></i>
                            </a>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-lg px-5 py-3 d-inline-flex align-items-center justify-content-center fw-bold" style="background: rgba(255,255,255,0.1); border: 2px solid rgba(255,255,255,0.25); color:white; border-radius:50px; backdrop-filter: blur(10px);">
                                Staff Login
                            </a>
                        }
                        else
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-lg px-5 py-3 fw-bold" style="background: linear-gradient(135deg, #3b82f6, #8b5cf6); border:none; color:white; border-radius:50px; box-shadow: 0 8px 30px rgba(59,130,246,0.4);">
                                    <i class="bi bi-speedometer2 me-2"></i> Admin Dashboard
                                </a>
                            }
                            else if (User.IsInRole("Doctor"))
                            {
                                <a asp-controller="Doctor" asp-action="Dashboard" class="btn btn-lg px-5 py-3 fw-bold" style="background: linear-gradient(135deg, #3b82f6, #8b5cf6); border:none; color:white; border-radius:50px; box-shadow: 0 8px 30px rgba(59,130,246,0.4);">
                                    <i class="bi bi-calendar-check-fill me-2"></i> Doctor Portal
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Patient" asp-action="Dashboard" class="btn btn-lg px-5 py-3 fw-bold" style="background: linear-gradient(135deg, #3b82f6, #8b5cf6); border:none; color:white; border-radius:50px; box-shadow: 0 8px 30px rgba(59,130,246,0.4);">
                                    <i class="bi bi-person-fill me-2"></i> Patient Portal
                                </a>
                            }
                        }
                    </div>
                    <!-- Trust Stats -->
                    <div class="d-flex gap-4 flex-wrap animate-fade-in-up delay-3">
                        <div class="text-center">
                            <div class="h3 fw-bold mb-0" style="color:#60a5fa;" data-count-to="500" data-count-duration="1500">0</div>
                            <small style="color:rgba(255,255,255,0.5);">Expert Doctors</small>
                        </div>
                        <div style="width:1px; background:rgba(255,255,255,0.15);"></div>
                        <div class="text-center">
                            <div class="h3 fw-bold mb-0" style="color:#a78bfa;" data-count-to="10000" data-count-duration="2000">0</div>
                            <small style="color:rgba(255,255,255,0.5);">Patients Served</small>
                        </div>
                        <div style="width:1px; background:rgba(255,255,255,0.15);"></div>
                        <div class="text-center">
                            <div class="h3 fw-bold mb-0" style="color:#34d399;">24/7</div>
                            <small style="color:rgba(255,255,255,0.5);">Support Available</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 d-none d-lg-block position-relative">
                <div class="position-relative animate-fade-in-up delay-2">
                    <!-- Floating Glass Card -->
                    <div class="p-4 p-xl-5 animate-float" style="background: rgba(255,255,255,0.08); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.12); border-radius: 1.5rem;">
                        <div class="d-flex align-items-center mb-4">
                            <div class="p-3 me-4" style="background: linear-gradient(135deg, rgba(59,130,246,0.2), rgba(139,92,246,0.15)); border-radius: 1rem;">
                                <i class="bi bi-heart-pulse text-white fs-2"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-1 text-white">Expert Physicians</h4>
                                <span style="color:rgba(255,255,255,0.6);" class="fw-medium">Over 50+ specialists available</span>
                            </div>
                        </div>
                        <div class="d-flex align-items-center mb-4">
                            <div class="p-3 me-4" style="background: linear-gradient(135deg, rgba(16,185,129,0.2), rgba(13,148,136,0.15)); border-radius: 1rem;">
                                <i class="bi bi-clipboard2-pulse text-white fs-2"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-1 text-white">Digital Records</h4>
                                <span style="color:rgba(255,255,255,0.6);" class="fw-medium">100% secure & private health tracking</span>
                            </div>
                        </div>
                        <div class="d-flex align-items-center">
                            <div class="p-3 me-4" style="background: linear-gradient(135deg, rgba(14,165,233,0.2), rgba(6,182,212,0.15)); border-radius: 1rem;">
                                <i class="bi bi-calendar-check text-white fs-2"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-1 text-white">Easy Scheduling</h4>
                                <span style="color:rgba(255,255,255,0.6);" class="fw-medium">Book appointments in seconds</span>
                            </div>
                        </div>
                    </div>
                    <!-- Decorative floating elements -->
                    <div class="position-absolute" style="top:-30px; right:-20px; width:80px; height:80px; background:linear-gradient(135deg, rgba(139,92,246,0.3), rgba(59,130,246,0.2)); border-radius:50%; filter:blur(1px); animation: float 4s ease-in-out infinite;"></div>
                    <div class="position-absolute" style="bottom:-20px; left:-30px; width:60px; height:60px; background:linear-gradient(135deg, rgba(16,185,129,0.3), rgba(14,165,233,0.2)); border-radius:50%; filter:blur(1px); animation: float 5s ease-in-out infinite reverse;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══ FEATURES SECTION ═══ -->
<div class="py-5" style="background: white;">
    <div class="container py-5">
        <div class="text-center mb-5 mx-auto animate-fade-in-up" style="max-width: 700px;">
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle px-3 py-2 mb-3 d-inline-block fw-bold text-uppercase" style="letter-spacing:1px; font-size:0.7rem;">Our Services</span>
            <h2 class="display-5 fw-bold text-dark" style="letter-spacing:-0.03em;">Comprehensive <span class="text-gradient">Healthcare</span> Services</h2>
            <p class="text-secondary lead mt-3">Professional tools for doctors, administrators, and seamless experiences for patients.</p>
        </div>

        <div class="row g-4 pt-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 feature-card">
                    <div class="card-body text-center p-2">
                        <div class="icon-box-primary p-3 mb-4 mx-auto" style="width:70px;height:70px;border-radius:1rem;">
                            <i class="bi bi-calendar-range fs-2"></i>
                        </div>
                        <h4 class="fw-bold mb-3 text-dark">Smart Scheduling</h4>
                        <p class="text-secondary mb-0">Book appointments instantly, manage availability, and reduce no-shows with automated reminders.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 feature-card">
                    <div class="card-body text-center p-2">
                        <div class="icon-box-success p-3 mb-4 mx-auto" style="width:70px;height:70px;border-radius:1rem;">
                            <i class="bi bi-file-earmark-medical fs-2"></i>
                        </div>
                        <h4 class="fw-bold mb-3 text-dark">Digital Records</h4>
                        <p class="text-secondary mb-0">Access complete medical histories, lab results, and prescriptions securely from anywhere.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 feature-card">
                    <div class="card-body text-center p-2">
                        <div class="icon-box-info p-3 mb-4 mx-auto" style="width:70px;height:70px;border-radius:1rem;">
                            <i class="bi bi-credit-card-2-front fs-2"></i>
                        </div>
                        <h4 class="fw-bold mb-3 text-dark">Seamless Billing</h4>
                        <p class="text-secondary mb-0">Transparent invoicing and secure payment processing with detailed financial reporting.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══ CTA SECTION ═══ -->
<div class="cta-gradient text-white py-5">
    <div class="container py-5 text-center position-relative" style="z-index:1;">
        <h2 class="display-5 fw-bold mb-4" style="letter-spacing:-0.03em;">Ready to get started?</h2>
        <p class="lead mb-5 mx-auto fs-5" style="max-width: 600px; color:rgba(255,255,255,0.6);">Join thousands of doctors and patients already using our professional healthcare platform.</p>
        @if (!isAuthenticated)
        {
            <a asp-controller="Account" asp-action="Register" class="btn btn-lg px-5 py-3 fw-bold" style="background:white; color:#1e40af; border-radius:50px; box-shadow: 0 8px 30px rgba(0,0,0,0.2);">
                Get Started Now <i class="bi bi-arrow-right ms-2"></i>
            </a>
        }
    </div>
</div>