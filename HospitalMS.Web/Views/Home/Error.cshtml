@model HospitalMS.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}
<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-8 text-center">
            <h1 class="display-1 text-danger">Error</h1>
            <h2 class="mb-4">An error occurred while processing your request.</h2>
            @if (Model.ShowRequestId)
            {
                <p class="text-muted">
                    <strong>Request ID:</strong> @Model.RequestId
                </p>
            }
            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Return to Home</a>
            </div>
        </div>
    </div>
</div>