@model HospitalMS.Web.ViewModels.DoctorEditViewModel
@{
    ViewData["Title"] = "Edit Doctor";
}
<div class="container py-5">
    <div class="row mb-5 justify-content-center">
        <div class="col-lg-8 text-center text-lg-start">
            <h2 class="display-6 fw-bold text-gray-800">Edit Doctor Profile</h2>
            <p class="text-muted lead mb-0">Update professional details and system settings.</p>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary bg-opacity-10 py-3 border-bottom-0">
                    <div class="d-flex align-items-center">
                        <div class="avatar-circle bg-white text-primary rounded-circle me-3 fw-bold d-flex align-items-center justify-content-center border" style="width: 48px; height: 48px; font-size: 1.25rem;">
                            <i class="bi bi-person-badge"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-primary mb-0">Doctor Information</h5>
                            <small class="text-muted">ID: @Model.Id</small>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4 bg-white">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="FullName" />
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="LicenseNumber" /> 
                        @if (ViewData.ModelState.ErrorCount > 0)
                        {
                            <div class="alert alert-danger border-0 shadow-sm mb-4">
                                <ul class="mb-0 ps-3">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small text-uppercase">Full Name</label>
                                <input type="text" class="form-control bg-light" value="@Model.FullName" readonly disabled />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small text-uppercase">Email</label>
                                <input type="text" class="form-control bg-light" value="@Model.Email" readonly disabled />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small text-uppercase">License Number</label>
                                <input type="text" class="form-control bg-light" value="@Model.LicenseNumber" readonly disabled />
                            </div>
                        </div>
                        <hr class="my-4 opacity-25" />
                        <h6 class="fw-bold text-dark mb-4"><i class="bi bi-briefcase me-2 text-primary"></i>Professional Details</h6>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label asp-for="Specialization" class="form-label fw-bold text-muted small text-uppercase">Specialization *</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-patch-check"></i></span>
                                    <input asp-for="Specialization" class="form-control border-start-0 bg-light-subtle" placeholder="e.g. Cardiology" />
                                </div>
                                <span asp-validation-for="Specialization" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DepartmentId" class="form-label fw-bold text-muted small text-uppercase">Department</label>
                                <select asp-for="DepartmentId" class="form-select bg-light-subtle" asp-items="ViewBag.Departments">
                                    <option value="">-- Select Department --</option>
                                </select>
                                <span asp-validation-for="DepartmentId" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="YearsOfExperience" class="form-label fw-bold text-muted small text-uppercase">Experience (Years)</label>
                                <input asp-for="YearsOfExperience" type="number" class="form-control bg-light-subtle" min="0" />
                                <span asp-validation-for="YearsOfExperience" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ConsultationFee" class="form-label fw-bold text-muted small text-uppercase">Consultation Fee</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted">$</span>
                                    <input asp-for="ConsultationFee" type="number" step="0.01" class="form-control border-start-0 bg-light-subtle" />
                                </div>
                                <span asp-validation-for="ConsultationFee" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <div class="row g-4 mb-4">
                            <div class="col-12">
                                <label asp-for="Qualifications" class="form-label fw-bold text-muted small text-uppercase">Qualifications</label>
                                <textarea asp-for="Qualifications" class="form-control bg-light-subtle" rows="2" placeholder="e.g. MBBS, MD, FRCS"></textarea>
                                <span asp-validation-for="Qualifications" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Bio" class="form-label fw-bold text-muted small text-uppercase">Biography</label>
                                <textarea asp-for="Bio" class="form-control bg-light-subtle" rows="4" placeholder="Professional summary..."></textarea>
                                <span asp-validation-for="Bio" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label fw-bold text-muted small text-uppercase">Phone Contact</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-telephone"></i></span>
                                    <input asp-for="PhoneNumber" class="form-control border-start-0 bg-light-subtle" />
                                </div>
                                <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <hr class="my-4 opacity-25" />
                        <div class="bg-light p-3 rounded border">
                            <div class="form-check form-switch">
                                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" role="switch" id="availabilitySwitch">
                                <label class="form-check-label fw-bold" for="availabilitySwitch">Available for Booking</label>
                                <div class="form-text text-muted small">Disable this to temporarily hide the doctor from public searches.</div>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-3 align-items-center mt-5">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4 fw-bold text-muted">Cancel</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm hover-lift transition-all">
                                <i class="bi bi-save me-2"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}