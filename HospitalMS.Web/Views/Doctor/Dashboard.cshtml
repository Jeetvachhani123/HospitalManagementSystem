@model HospitalMS.Web.ViewModels.DoctorDashboardViewModel
@{
    ViewData["Title"] = "Doctor Dashboard";
}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 animate-fade-in-up">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1" style="letter-spacing:-0.03em;">
                Welcome, <span class="text-gradient">Dr. @Model.Doctor.FullName</span>
            </h1>
            <p class="text-secondary fw-medium mb-0">Here's your schedule and activity overview for today.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Appointment" asp-action="Index" class="btn btn-outline-primary rounded-pill px-3">
                <i class="bi bi-calendar-week me-1"></i> Full Schedule
            </a>
            <a asp-controller="Doctor" asp-action="ManageWorkingHours" class="btn btn-outline-secondary rounded-pill px-3">
                <i class="bi bi-gear me-1"></i> Availability
            </a>
        </div>
    </div>
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6 animate-fade-in-up delay-1">
            <div class="card border-0 h-100 hover-lift" style="background: var(--gradient-primary); color:white;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-uppercase fw-bold mb-2" style="color:rgba(255,255,255,0.7); letter-spacing:0.05em; font-size:0.7rem;">Appointments Today</div>
                            <div class="display-6 fw-bold" data-count-to="@Model.TodayAppointmentsCount" data-count-duration="1000">@Model.TodayAppointmentsCount</div>
                        </div>
                        <i class="bi bi-calendar-day fs-1 opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 animate-fade-in-up delay-2">
            <div class="card border-0 h-100 hover-lift" style="background: var(--gradient-warning); color:white;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-uppercase fw-bold mb-2" style="color:rgba(255,255,255,0.8); letter-spacing:0.05em; font-size:0.7rem;">Pending Requests</div>
                            <div class="display-6 fw-bold" data-count-to="@Model.PendingApprovalsCount" data-count-duration="800">@Model.PendingApprovalsCount</div>
                        </div>
                        <i class="bi bi-bell fs-1 opacity-25"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3 px-4">
                    <a asp-controller="Appointment" asp-action="PendingApprovals" class="text-white small stretched-link fw-bold text-decoration-none" style="opacity:0.8;">Review Requests &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 animate-fade-in-up delay-3">
            <div class="card border-0 h-100 hover-lift" style="background: var(--gradient-success); color:white;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-uppercase fw-bold mb-2" style="color:rgba(255,255,255,0.7); letter-spacing:0.05em; font-size:0.7rem;">Total Patients Treated</div>
                            <div class="display-6 fw-bold" data-count-to="@Model.TotalPatientsTreated" data-count-duration="1200">@Model.TotalPatientsTreated</div>
                        </div>
                        <i class="bi bi-people fs-1 opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-lg-8 animate-fade-in-up delay-3">
            <div class="card border-0 h-100">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 fw-bold text-gradient">📋 Today's Schedule</h6>
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle px-3 py-2 fw-bold">@DateTime.Now.ToString("dd MMM yyyy")</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Time</th>
                                    <th>Patient</th>
                                    <th>Status</th>
                                    <th class="text-end pe-4">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.UpcomingAppointments != null && Model.UpcomingAppointments.Any())
                                {
                                    foreach (var appt in Model.UpcomingAppointments)
                                    {
                                        <tr class="stagger-item">
                                            <td class="ps-4 fw-bold text-dark">
                                                @DateTime.Today.Add(appt.StartTime).ToString("hh:mm") <small class="text-muted">@DateTime.Today.Add(appt.StartTime).ToString("tt")</small>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-circle rounded-circle me-2 fw-bold d-flex align-items-center justify-content-center" style="width:32px;height:32px; font-size:0.75rem;">
                                                        @(!string.IsNullOrEmpty(appt.PatientName) ? appt.PatientName[0] : '?')
                                                    </div>
                                                    <div>@appt.PatientName</div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-@(appt.Status == "Confirmed" ? "success" : "info")">
                                                    @appt.Status
                                                </span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <a asp-controller="Appointment" asp-action="Details" asp-route-id="@appt.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">View</a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">
                                            <i class="bi bi-calendar-check display-4 opacity-25"></i>
                                            <p class="mt-2">No appointments scheduled for today.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 animate-fade-in-up delay-4">
            <div class="card border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-secondary">⚡ Quick Actions</h6>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-controller="Appointment" asp-action="PendingApprovals" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 px-4">
                        <div>
                            <i class="bi bi-check-circle me-2 text-warning"></i> Approve Requests
                        </div>
                        @if (Model.PendingApprovalsCount > 0)
                        {
                            <span class="badge bg-danger rounded-pill">@Model.PendingApprovalsCount</span>
                        }
                    </a>
                    <a asp-controller="Doctor" asp-action="ManageWorkingHours" class="list-group-item list-group-item-action py-3 px-4">
                        <i class="bi bi-clock me-2 text-primary"></i> Update My Hours
                    </a>
                    <a asp-controller="Appointment" asp-action="History" class="list-group-item list-group-item-action py-3 px-4">
                        <i class="bi bi-archive me-2 text-secondary"></i> View Past Records
                    </a>
                    <a asp-controller="MedicalRecord" asp-action="Index" class="list-group-item list-group-item-action py-3 px-4">
                        <i class="bi bi-file-medical me-2 text-info"></i> Medical Records
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>