@model HospitalMS.Web.ViewModels.DoctorListViewModel
@{
    ViewData["Title"] = User.IsInRole("Admin") ? "Manage Doctors" : "Find a Doctor";
}
<div class="container py-4">
    @if (User.IsInRole("Admin"))
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 fw-bold text-gray-800">Manage Doctors</h1>
                <p class="text-muted mb-0">Overview of all medical staff and their availability.</p>
            </div>
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-person-plus-fill me-2"></i> Add New Doctor
            </a>
        </div>
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4">Doctor Name</th>
                                <th>Specialization</th>
                                <th>Experience</th>
                                <th>Status</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doctor in Model.Doctors)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle bg-primary-subtle text-primary rounded-circle me-3 fw-bold d-flex align-items-center justify-content-center" style="width:40px;height:40px;">
                                                @doctor.FullName.Substring(0, 1)
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">Dr. @doctor.FullName</div>
                                                <div class="small text-muted">@doctor.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-light text-dark border fw-normal">@doctor.Specialization</span></td>
                                    <td class="text-muted small">@doctor.YearsOfExperience Years</td>
                                    <td>
                                        @if (doctor.IsAvailable)
                                        {
                                            <span class="badge bg-success-subtle text-success rounded-pill px-3">Available</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary rounded-pill px-3">Unavailable</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <a asp-action="Edit" asp-route-id="@doctor.Id" class="btn btn-sm btn-outline-secondary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal" data-doctor-id="@doctor.Id" data-doctor-name="Dr. @doctor.FullName" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            @if (Model.TotalPages > 1)
            {
                <div class="card-footer bg-white py-3 border-0 d-flex justify-content-center">
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link border-0" asp-route-page="@(Model.CurrentPage - 1)">Previous</a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link border-0 rounded-circle mx-1" asp-route-page="@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link border-0" asp-route-page="@(Model.CurrentPage + 1)">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center mb-5">
            <h1 class="display-6 fw-bold text-gray-800">Find Your Specialist</h1>
            <p class="text-muted lead mx-auto" style="max-width: 600px;">
                Browse our list of qualified doctors and book an appointment online.
            </p>
            <div class="card border-0 shadow-sm p-2 mx-auto mt-4" style="max-width: 700px; border-radius: 50px;">
                <form method="get" asp-action="Index" class="d-flex align-items-center">
                    <div class="flex-grow-1 border-end position-relative">
                        <i class="bi bi-search position-absolute text-muted" style="left: 20px; top: 50%; transform: translateY(-50%);"></i>
                        <input type="text" name="searchQuery" value="@Model.SearchQuery" class="form-control border-0 shadow-none ps-5 py-3 rounded-pill" placeholder="Search doctor name..." style="background:transparent;">
                    </div>
                    <div class="flex-grow-1 px-2 position-relative d-none d-md-block" style="max-width: 250px;">
                        <select name="specialization" class="form-select border-0 shadow-none py-3" style="cursor:pointer; background-color:transparent;">
                            <option value="">All Specialties</option>
                            @foreach (var spec in Model.Specializations)
                            {
                                <option value="@spec" selected="@(spec == Model.SelectedSpecialization)">@spec</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 m-1 fw-bold shadow-sm">Search</button>
                </form>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery) || !string.IsNullOrWhiteSpace(Model.SelectedSpecialization))
            {
                <div class="mt-3">
                    <span class="text-muted small me-2">Found @Model.TotalCount results</span>
                    <a asp-action="Index" class="text-decoration-none small fw-bold">Clear Filters</a>
                </div>
            }
        </div>
        @if (Model.Doctors.Any())
        {
            <div class="row g-4">
                @foreach (var doctor in Model.Doctors)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-0 shadow-sm hover-lift transition-all">
                            <div class="card-body p-4 text-center">
                                <div class="mb-3 position-relative d-inline-block">
                                    <div class="avatar-circle bg-light text-primary fw-bold d-flex align-items-center justify-content-center rounded-circle mx-auto" style="width: 80px; height: 80px; font-size: 2rem;">
                                        @doctor.FullName.Substring(0, 1)
                                    </div>
                                    <span class="position-absolute bottom-0 end-0 p-1 bg-@(doctor.IsAvailable ? "success" : "secondary") border border-white rounded-circle">
                                        <span class="visually-hidden">@(doctor.IsAvailable ? "Available" : "Unavailable")</span>
                                    </span>
                                </div>
                                <h5 class="card-title fw-bold text-dark mb-1">Dr. @doctor.FullName</h5>
                                <p class="text-primary small text-uppercase fw-bold mb-3">@doctor.Specialization</p>
                                <div class="d-flex justify-content-center gap-3 mb-4 text-muted small">
                                    <div><i class="bi bi-briefcase me-1"></i> @doctor.YearsOfExperience Years</div>
                                    <div class="vr"></div>
                                    <div><i class="bi bi-cash me-1"></i> ₹@doctor.ConsultationFee</div>
                                </div>
                                <div class="d-grid gap-2">
                                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Patient"))
                                    {
                                        if (doctor.IsAvailable)
                                        {
                                            <a asp-controller="Appointment" asp-action="Request" asp-route-doctorId="@doctor.Id" class="btn btn-primary rounded-pill shadow-sm fw-bold">
                                                Book Appointment
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-secondary rounded-pill opacity-75" disabled>Currently Unavailable</button>
                                        }
                                    }
                                    else if (User.Identity?.IsAuthenticated != true)
                                    {
                                        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path" class="btn btn-outline-primary rounded-pill">
                                            Login to Book
                                        </a>
                                    }
                                    <a asp-controller="Doctor" asp-action="Details" asp-route-id="@doctor.Id" class="btn btn-link text-decoration-none text-muted small">
                                        View Profile
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            @if (Model.TotalPages > 1)
            {
                <div class="mt-5 d-flex justify-content-center">
                    <nav aria-label="Page navigation">
                        <ul class="pagination">
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link border-0 shadow-sm rounded-circle me-2" asp-route-page="@(Model.CurrentPage - 1)" asp-route-searchQuery="@Model.SearchQuery" asp-route-specialization="@Model.SelectedSpecialization"><i class="bi bi-arrow-left"></i></a>
                            </li>
                            <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">Page @Model.CurrentPage of @Model.TotalPages</span></li>
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link border-0 shadow-sm rounded-circle ms-2" asp-route-page="@(Model.CurrentPage + 1)" asp-route-searchQuery="@Model.SearchQuery" asp-route-specialization="@Model.SelectedSpecialization"><i class="bi bi-arrow-right"></i></a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-search display-1 text-muted opacity-25"></i>
                <h3 class="mt-3 text-muted">No doctors found</h3>
                <p class="text-muted">Try adjusting your filters or search terms.</p>
                <a asp-action="Index" class="btn btn-outline-primary mt-3">Reset Filters</a>
            </div>
        }
    }
</div>
@if (User.IsInRole("Admin"))
{
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Confirm Deletion</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-muted">
                    Are you sure you want to delete <strong id="doctorNameToDelete" class="text-dark"></strong>? This action cannot be undone.
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <form asp-action="Delete" method="post">
                        <input type="hidden" name="id" id="doctorIdToDelete" />
                        <button type="submit" class="btn btn-danger rounded-pill px-4">Delete Doctor</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    @section Scripts {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                var deleteModal = document.getElementById('deleteModal');
                if (deleteModal) {
                    deleteModal.addEventListener('show.bs.modal', function (event) {
                        var button = event.relatedTarget;
                        document.getElementById('doctorIdToDelete').value = button.getAttribute('data-doctor-id');
                        document.getElementById('doctorNameToDelete').textContent = button.getAttribute('data-doctor-name');
                    });
                }
            });
        </script>
    }
}