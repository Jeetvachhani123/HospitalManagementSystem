@model IEnumerable<HospitalMS.BL.DTOs.Department.DepartmentDto>
@{
    ViewData["Title"] = "Departments";
    bool isAdmin = User.IsInRole("Admin");
}
<div class="container-fluid py-4 min-vh-100 bg-light">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h2 class="h3 fw-bold text-gray-800 mb-0">Hospital Departments</h2>
            <p class="text-muted small mb-0">Manage clinical units and facility locations.</p>
        </div>
        @if (isAdmin)
        {
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold hover-lift transition-all">
                <i class="bi bi-building-add me-2"></i>Add Department
            </a>
        }
    </div>
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2 text-success"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="bg-white rounded-circle shadow-sm d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                <i class="bi bi-building text-muted opacity-50 display-4"></i>
            </div>
            <h4 class="text-muted fw-normal">No Departments Found</h4>
            <p class="text-muted small">Initialize your hospital structure by adding a department.</p>
        </div>
    }
    else
    {
        <div class="row g-4 justify-content-center">
            @foreach (var dept in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden hover-lift transition-all">
                        <div class="card-header bg-white border-bottom-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-start">
                            <div class="avatar-circle bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 50px; height: 50px; font-size: 1.5rem;">
                                @dept.Name.Substring(0, 1)
                            </div>
                            @if (isAdmin)
                            {
                                <div class="dropdown">
                                    <button class="btn btn-light btn-sm rounded-circle shadow-sm" type="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical text-muted"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg">
                                        <li><a class="dropdown-item fw-medium" asp-action="Edit" asp-route-id="@dept.Id"><i class="bi bi-pencil me-2 text-warning"></i>Edit Details</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form asp-action="Delete" asp-route-id="@dept.Id" method="post" onsubmit="return confirm('Deleting this department is irreversible. Continue?');">
                                                <button type="submit" class="dropdown-item fw-medium text-danger">
                                                    <i class="bi bi-trash me-2"></i>Delete
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            }
                        </div>
                        <div class="card-body px-4 pt-3 pb-4">
                            <h5 class="card-title fw-bold text-dark mb-1">@dept.Name</h5>
                            <p class="card-text text-muted small mb-3 text-truncate" title="@dept.Description">@dept.Description</p>
                            <div class="d-flex align-items-center mb-3">
                                <i class="bi bi-geo-alt-fill text-danger me-2"></i>
                                <span class="text-dark fw-medium small">@dept.Location</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top border-light">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-pill bg-light border px-3 py-1 d-flex align-items-center">
                                        <i class="bi bi-person-badge me-2 text-muted"></i>
                                        <span class="fw-bold text-dark small">@dept.DoctorCount Staff</span>
                                    </div>
                                </div>
                                @if (dept.IsActive)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-2 py-1 small fw-medium">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-2 py-1 small fw-medium">Inactive</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
<style>
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
    }

    .transition-all {
        transition: all 0.3s ease;
    }
</style>