@model IEnumerable<HospitalMS.Web.ViewModels.InvoiceViewModel>
@{
    ViewData["Title"] = "Financial Records";
    var pendingCount = Model.Count(i => !i.IsPaid);
    var totalDue = Model.Where(i => !i.IsPaid).Sum(i => i.Amount);
}
<div class="container-fluid py-4 min-vh-100 bg-light">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h2 class="h3 fw-bold text-gray-800 mb-0">Billing & Invoices</h2>
            <p class="text-muted small mb-0">Manage payments and financial history.</p>
        </div>
        <div class="d-flex gap-3">
            <div class="card border-0 shadow-sm px-3 py-2 d-flex flex-row align-items-center bg-white rounded-pill">
                <div class="rounded-circle bg-warning bg-opacity-10 p-2 me-2">
                    <i class="bi bi-hourglass-split text-warning"></i>
                </div>
                <div>
                    <small class="d-block text-muted" style="font-size: 0.7rem; line-height: 1;">PENDING</small>
                    <span class="fw-bold text-dark">@pendingCount Bills</span>
                </div>
            </div>
            <div class="card border-0 shadow-sm px-3 py-2 d-flex flex-row align-items-center bg-white rounded-pill">
                <div class="rounded-circle bg-danger bg-opacity-10 p-2 me-2">
                    <i class="bi bi-cash-stack text-danger"></i>
                </div>
                <div>
                    <small class="d-block text-muted" style="font-size: 0.7rem; line-height: 1;">TOTAL DUE</small>
                    <span class="fw-bold text-dark">@totalDue.ToString("C")</span>
                </div>
            </div>
        </div>
    </div>
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2 text-success"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <div class="bg-light rounded-circle shadow-sm d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-receipt text-muted opacity-50 display-4"></i>
                    </div>
                    <h4 class="text-muted fw-normal">No Invoices Found</h4>
                    <p class="text-muted small">All payments are up to date.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-uppercase text-muted small fw-bold">
                            <tr>
                                <th class="ps-4 py-3 border-0">Invoice ID</th>
                                <th class="py-3 border-0">Issued To</th>
                                <th class="py-3 border-0">Provider</th>
                                <th class="py-3 border-0">Date & Due</th>
                                <th class="py-3 border-0">Amount</th>
                                <th class="py-3 border-0">Status</th>
                                <th class="pe-4 py-3 border-0 text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="transition-colors hover-bg-light">
                                    <td class="ps-4 py-3">
                                        <span class="fw-bold text-dark font-monospace">#INV-@item.Id.ToString("D5")</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle bg-primary bg-opacity-10 text-primary rounded-circle me-2 d-flex align-items-center justify-content-center fw-bold small" style="width: 32px; height: 32px;">
                                                @(string.IsNullOrEmpty(item.PatientName) ? "?" : item.PatientName.Substring(0, 1))
                                            </div>
                                            <span class="fw-medium text-dark">@item.PatientName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-muted small"><i class="bi bi-person-fill me-1"></i>Dr. @item.DoctorName</span>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column small">
                                            <span class="text-dark">@item.IssueDate.ToString("MMM dd, yyyy")</span>
                                            @if (!item.IsPaid && item.DueDate < DateTime.Today)
                                            {
                                                <span class="text-danger fw-bold"><i class="bi bi-exclamation-circle me-1"></i>Due: @item.DueDate.ToString("MMM dd")</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Due: @item.DueDate.ToString("MMM dd")</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="fw-bold text-dark">@item.Amount.ToString("C")</td>
                                    <td>
                                        @if (item.IsPaid)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-1 fw-bold">
                                                <i class="bi bi-check2-circle me-1"></i> PAID
                                            </span>
                                        }
                                        else if (item.DueDate < DateTime.Today)
                                        {
                                            <span class="badge bg-danger text-white rounded-pill px-3 py-1 fw-bold shadow-sm">
                                                OVERDUE
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning bg-opacity-10 text-dark border border-warning border-opacity-25 rounded-pill px-3 py-1 fw-bold">
                                                PENDING
                                            </span>
                                        }
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="btn-group">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-light btn-sm rounded-pill px-3 me-2 fw-bold text-muted border shadow-sm">
                                                View
                                            </a>
                                            @if (!item.IsPaid && (User.IsInRole("Patient") || User.IsInRole("Admin")))
                                            {
                                                <a asp-action="Pay" asp-route-id="@item.Id" class="btn btn-success btn-sm rounded-pill px-3 fw-bold shadow-sm hover-lift">
                                                    Pay Now
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>