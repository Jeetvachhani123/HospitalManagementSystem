@model HospitalMS.Web.ViewModels.PayInvoiceViewModel
@{
    ViewData["Title"] = "Secure Payment";
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="text-center mb-5">
                <div class="bg-success text-white rounded-circle d-inline-flex px-4 py-4 shadow-lg mb-4">
                    <i class="bi bi-shield-lock-fill display-4"></i>
                </div>
                <h2 class="h3 fw-bold text-gray-800">Secure Payment Gateway</h2>
                <p class="text-muted small mb-0">Complete your transaction with confidence.</p>
            </div>
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden position-relative">
                <div class="card-header bg-dark text-white text-center py-5 border-bottom-0 position-relative z-1">
                    <small class="text-white-50 text-uppercase fw-bold letter-spacing-2 d-block mb-1">Total Amount Due</small>
                    <h1 class="display-3 fw-bold mb-0 text-white">$@Model.Amount.ToString("N2")</h1>
                    <div class="position-absolute bottom-0 start-50 translate-middle-x mb-n4 bg-white px-4 py-2 rounded-pill shadow-sm border">
                        <small class="text-uppercase fw-bold text-muted small"><i class="bi bi-receipt-cutoff me-1"></i> Invoice #@Model.InvoiceId</small>
                    </div>
                </div>
                <div class="card-body p-4 pt-5 bg-white position-relative z-0">
                    <div class="row mb-5 justify-content-center text-center">
                        <div class="col-6 border-end">
                            <small class="d-block text-muted text-uppercase fw-bold" style="font-size: 0.65rem;">Patient Name</small>
                            <span class="fw-bold text-dark text-truncate d-block px-2">@Model.PatientName</span>
                        </div>
                        <div class="col-6">
                            <small class="d-block text-muted text-uppercase fw-bold" style="font-size: 0.65rem;">Date Issued</small>
                            <span class="fw-bold text-dark text-truncate d-block px-2">@DateTime.Now.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                    <form asp-action="Pay" method="post" id="paymentForm">
                        <input type="hidden" asp-for="InvoiceId" />
                        <input type="hidden" asp-for="PatientName" />
                        <input type="hidden" asp-for="Amount" />
                        <div class="mb-4">
                            <label asp-for="PaymentMethod" class="form-label fw-bold text-muted small text-uppercase">Payment Method</label>
                            <select asp-for="PaymentMethod" class="form-select form-select-lg bg-light-subtle rounded-3" id="paymentMethodSelect">
                                <option value="">Select Method...</option>
                                <option value="Credit Card">Credit / Debit Card</option>
                                <option value="Insurance">Insurance Coverage</option>
                                <option value="Cash">Cash (In-Clinic)</option>
                            </select>
                            <span asp-validation-for="PaymentMethod" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div id="cardDetails" class="d-none bg-light p-3 rounded-3 mb-4 border">
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted text-uppercase">Card Number</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-credit-card"></i></span>
                                    <input type="text" class="form-control border-start-0" placeholder="0000 0000 0000 0000" maxlength="19">
                                </div>
                            </div>
                            <div class="row g-3">
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted text-uppercase">Expiry</label>
                                    <input type="text" class="form-control" placeholder="MM/YY" maxlength="5">
                                </div>
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted text-uppercase">CVC</label>
                                    <div class="input-group">
                                        <input type="text" class="form-control border-end-0" placeholder="123" maxlength="3">
                                        <span class="input-group-text bg-white border-start-0 text-muted"><i class="bi bi-question-circle"></i></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-dark btn-lg py-3 rounded-pill shadow-lg hover-lift transition-all fw-bold">
                                <i class="bi bi-lock-fill me-2"></i> Confirm Payment
                            </button>
                            <a asp-action="Index" class="btn btn-link text-decoration-none text-muted small fw-bold">Cancel Transaction</a>
                        </div>
                    </form>
                    <div class="mt-4 text-center">
                        <img src="https://cdn-icons-png.flaticon.com/512/196/196566.png" height="24" class="mx-2 opacity-50 grayscale" alt="Visa">
                        <img src="https://cdn-icons-png.flaticon.com/512/196/196561.png" height="24" class="mx-2 opacity-50 grayscale" alt="Mastercard">
                        <img src="https://cdn-icons-png.flaticon.com/512/196/196578.png" height="24" class="mx-2 opacity-50 grayscale" alt="Amex">
                    </div>
                </div>
                <div class="card-footer bg-light text-center py-3 border-top">
                    <small class="text-muted d-block"><i class="bi bi-shield-check me-1 text-success"></i> 256-bit SSL Encrypted Connection</small>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            $('#paymentMethodSelect').change(function() {
                if($(this).val() === 'Credit Card') {
                    $('#cardDetails').removeClass('d-none').hide().slideDown();
                } else {
                    $('#cardDetails').slideUp();
                }
            });
        });
    </script>
    <style>
        .grayscale {
            filter: grayscale(100%);
            transition: filter 0.3s;
        }

            .grayscale:hover {
                filter: grayscale(0%);
            }
    </style>
}