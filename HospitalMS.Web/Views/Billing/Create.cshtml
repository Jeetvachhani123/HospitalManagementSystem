@model HospitalMS.Web.ViewModels.GenerateInvoiceViewModel
@{
    ViewData["Title"] = "New Invoice";
}
<div class="container py-5">
    <div class="row mb-5 justify-content-center">
        <div class="col-lg-8 text-center text-lg-start">
            <h2 class="display-6 fw-bold text-gray-800">Generate Invoice</h2>
            <p class="text-muted lead mb-0">Create billing for completed appointments.</p>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-success bg-opacity-10 py-3 border-bottom-0">
                    <div class="d-flex align-items-center">
                        <div class="avatar-circle bg-white text-success rounded-circle me-3 fw-bold d-flex align-items-center justify-content-center border" style="width: 48px; height: 48px; font-size: 1.25rem;">
                            <i class="bi bi-file-earmark-text"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-success mb-0">Billing Details</h5>
                            <small class="text-muted">Fill out invoice particulars.</small>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4 bg-white">
                    <form asp-action="Create" method="post">
                        <input type="hidden" asp-for="AppointmentId" />
                        <input type="hidden" asp-for="PatientName" />
                        <input type="hidden" asp-for="DoctorName" />
                        <input type="hidden" asp-for="AppointmentDate" />
                        <div class="bg-success bg-opacity-10 p-4 rounded-3 border border-success border-opacity-25 mb-4 position-relative overflow-hidden">
                            <div class="row g-3">
                                <div class="col-md-6 border-end border-success border-opacity-25">
                                    <small class="text-uppercase fw-bold text-success opacity-75 small d-block mb-1">Patient</small>
                                    <h5 class="fw-bold text-dark mb-0">@Model.PatientName</h5>
                                </div>
                                <div class="col-md-6 ps-md-4">
                                    <small class="text-uppercase fw-bold text-success opacity-75 small d-block mb-1">Provider</small>
                                    <h6 class="fw-bold text-dark mb-0">Dr. @Model.DoctorName</h6>
                                    <small class="d-block text-success mt-1"><i class="bi bi-calendar-event me-1"></i>@Model.AppointmentDate.ToLongDateString()</small>
                                </div>
                            </div>
                            <i class="bi bi-receipt position-absolute bottom-0 end-0 opacity-10" style="font-size: 6rem; margin-right: -1rem; margin-bottom: -1rem; color: var(--bs-success);"></i>
                        </div>
                        @if (ViewData.ModelState.ErrorCount > 0)
                        {
                            <div class="alert alert-danger border-0 shadow-sm mb-4">
                                <ul class="mb-0 ps-3">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label asp-for="Amount" class="form-label fw-bold text-muted small text-uppercase">Total Amount ($) *</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted">$</span>
                                    <input asp-for="Amount" type="number" step="0.01" class="form-control border-start-0 bg-light-subtle fw-bold fs-5 text-dark" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Amount" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DueDate" class="form-label fw-bold text-muted small text-uppercase">Due Date *</label>
                                <input asp-for="DueDate" type="date" class="form-control bg-light-subtle" />
                                <span asp-validation-for="DueDate" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-3 align-items-center mt-5">
                            <a href="javascript:history.back()" class="btn btn-light rounded-pill px-4 fw-bold text-muted">Back</a>
                            <button type="submit" class="btn btn-success rounded-pill px-5 py-2 fw-bold shadow-sm hover-lift transition-all">
                                <i class="bi bi-check-lg me-2"></i> Issue Invoice
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}