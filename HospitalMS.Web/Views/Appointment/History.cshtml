@model IEnumerable<HospitalMS.Web.ViewModels.AppointmentViewModel>
@{
    ViewData["Title"] = "Appointment History";
}
<div class="container-fluid py-4 min-vh-100">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h4 fw-bold text-gray-800 mb-0">Past Appointments</h2>
            <p class="text-muted small mb-0">Archive of all previous consultations.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 btn-sm fw-bold">
            <i class="bi bi-calendar-event me-2"></i>Upcoming Appointments
        </a>
    </div>
    @if (Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-uppercase text-muted small fw-bold">
                        <tr>
                            <th class="ps-4 py-3 border-0">Date & Time</th>
                            @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
                            {
                                <th class="py-3 border-0">Patient</th>
                            }
                            @if (User.IsInRole("Admin") || User.IsInRole("Patient"))
                            {
                                <th class="py-3 border-0">Doctor</th>
                            }
                            <th class="py-3 border-0">Status</th>
                            <th class="py-3 border-0">Notes</th>
                            <th class="py-3 border-0 text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appointment in Model)
                        {
                            <tr class="transition-colors hover-bg-light">
                                <td class="ps-4 py-3">
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-dark">@appointment.AppointmentDate.ToString("MMM dd, yyyy")</span>
                                        <small class="text-muted">@appointment.StartTime.ToString(@"hh\:mm") - @appointment.EndTime.ToString(@"hh\:mm")</small>
                                    </div>
                                </td>
                                @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
                                {
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle bg-light text-primary rounded-circle me-2 d-flex align-items-center justify-content-center shadow-sm" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                                @(string.IsNullOrEmpty(appointment.PatientName) ? "?" : appointment.PatientName.Substring(0, 1))
                                            </div>
                                            <span class="fw-medium text-dark">@appointment.PatientName</span>
                                        </div>
                                    </td>
                                }
                                @if (User.IsInRole("Admin") || User.IsInRole("Patient"))
                                {
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle bg-light text-success rounded-circle me-2 d-flex align-items-center justify-content-center shadow-sm" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                                @(string.IsNullOrEmpty(appointment.DoctorName) ? "?" : appointment.DoctorName.Substring(0, 1))
                                            </div>
                                            <span class="fw-medium text-dark">Dr. @appointment.DoctorName</span>
                                        </div>
                                    </td>
                                }
                                <td>
                                    @{
                                        var statusClass = appointment.Status switch
                                        {
                                            "Completed" => "bg-success bg-opacity-10 text-success border border-success border-opacity-25",
                                            "Cancelled" => "bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25",
                                            "Pending" => "bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25",
                                            _ => "bg-secondary bg-opacity-10 text-secondary border"
                                        };
                                        var iconClass = appointment.Status switch
                                        {
                                            "Completed" => "bi-check-circle-fill",
                                            "Cancelled" => "bi-x-circle-fill",
                                            "Pending" => "bi-clock-fill",
                                            _ => "bi-info-circle-fill"
                                        };
                                    }
                                    <span class="badge @statusClass rounded-pill px-3 py-2 fw-medium">
                                        <i class="bi @iconClass me-1"></i> @appointment.Status
                                    </span>
                                </td>
                                <td class="text-muted small text-truncate" style="max-width: 200px;" title="@appointment.Reason">
                                    @(string.IsNullOrEmpty(appointment.Reason) ? "-" : appointment.Reason)
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-controller="Appointment" asp-action="Details" asp-route-id="@appointment.Id" class="btn btn-light btn-sm rounded-pill px-3 fw-bold text-primary shadow-sm">
                                        View Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="bg-white rounded-circle shadow-sm d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                <i class="bi bi-clock-history text-muted opacity-50 display-6"></i>
            </div>
            <h5 class="fw-bold text-dark">No History Found</h5>
            <p class="text-muted small">You haven't completed any appointments yet.</p>
        </div>
    }
</div>