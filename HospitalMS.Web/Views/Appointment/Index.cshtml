@model HospitalMS.Web.ViewModels.AppointmentListViewModel
@{
    ViewData["Title"] = "Appointments";
    var isDoctor = User.IsInRole("Doctor");
    var isPatient = User.IsInRole("Patient");
    var isAdmin = User.IsInRole("Admin");
}
<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="h3 fw-bold text-gray-800">
                @(isDoctor ? "My Schedule" : isPatient ? "My Appointments" : "All Appointments")
            </h1>
            <p class="text-muted mb-0">Manage and track your schedule efficiently.</p>
        </div>
        <div class="d-flex gap-2 mt-3 mt-md-0">
            @if (isPatient)
            {
                <a asp-controller="Doctor" asp-action="Index" class="btn btn-primary shadow-sm rounded-pill px-4">
                    <i class="bi bi-plus-lg me-1"></i> Book New Appointment
                </a>
            }
            <button class="btn btn-outline-secondary rounded-pill px-3" type="button" data-bs-toggle="collapse" data-bs-target="#filterPanel">
                <i class="bi bi-funnel me-1"></i> Filter
            </button>
            <div class="dropdown">
                <button class="btn btn-outline-secondary rounded-pill px-3 dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-download me-1"></i> Export
                </button>
                <ul class="dropdown-menu shadow border-0">
                    <li><a class="dropdown-item" asp-action="ExportToCSV"><i class="bi bi-file-earmark-spreadsheet me-2"></i> CSV</a></li>
                    <li><a class="dropdown-item" asp-action="ExportToExcel"><i class="bi bi-file-earmark-excel me-2"></i> Excel</a></li>
                    <li><a class="dropdown-item" asp-action="ExportToPDF"><i class="bi bi-file-earmark-pdf me-2"></i> PDF</a></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="collapse mb-4 @((!string.IsNullOrEmpty(Model.SearchQuery) || Model.FromDate.HasValue) ? "show" : "")" id="filterPanel">
        <div class="card border-0 shadow-sm bg-light">
            <div class="card-body">
                <form method="get" asp-action="Index" class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small text-muted text-uppercase fw-bold">Search</label>
                        <input type="text" name="searchQuery" value="@Model.SearchQuery" class="form-control border-0 shadow-none" placeholder="Search by name or ID..." />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted text-uppercase fw-bold">From Date</label>
                        <input type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control border-0 shadow-none" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted text-uppercase fw-bold">To Date</label>
                        <input type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control border-0 shadow-none" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-secondary w-100 fw-bold">Apply Filters</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">Date & Time</th>
                            @if (!isPatient)
                            {
                                <th>Patient</th>
                            }
                            @if (!isDoctor)
                            {
                                <th>Doctor</th>
                            }
                            <th>Status</th>
                            <th>Reason</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Appointments.Any())
                        {
                            foreach (var appt in Model.Appointments)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="date-badge text-center me-3 border rounded p-1 bg-light" style="min-width: 50px;">
                                                <small class="d-block text-muted text-uppercase fw-bold" style="font-size: 0.65rem;">@appt.AppointmentDate.ToString("MMM")</small>
                                                <span class="d-block h5 fw-bold mb-0 text-dark">@appt.AppointmentDate.Day</span>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@DateTime.Today.Add(appt.StartTime).ToString("hh:mm tt")</div>
                                                <div class="small text-muted">@DateTime.Today.Add(appt.EndTime).ToString("hh:mm tt")</div>
                                            </div>
                                        </div>
                                    </td>
                                    @if (!isPatient)
                                    {
                                        <td>
                                            <div class="fw-bold text-dark">@appt.PatientName</div>
                                        </td>
                                    }
                                    @if (!isDoctor)
                                    {
                                        <td>
                                            <div class="fw-bold text-dark">Dr. @appt.DoctorName</div>
                                            <div class="small text-muted">@appt.Specialization</div>
                                        </td>
                                    }
                                    <td>
                                        @{
                                            var statusColor = appt.Status switch
                                            {
                                                "Confirmed" => "success",
                                                "Pending" => "warning",
                                                "Cancelled" => "danger",
                                                "Completed" => "primary",
                                                _ => "secondary"
                                            };
                                        }
                                        <span class="badge bg-@statusColor-subtle text-@statusColor border border-@statusColor-subtle rounded-pill px-3">
                                            @appt.Status
                                        </span>
                                    </td>
                                    <td class="text-truncate" style="max-width: 200px;" title="@appt.Reason">
                                        <span class="text-muted small">@appt.Reason</span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <a asp-action="Details" asp-route-id="@appt.Id" class="btn btn-sm btn-outline-secondary" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (isDoctor && appt.Status == "Pending")
                                            {
                                                <a asp-action="PendingApprovals" class="btn btn-sm btn-outline-primary" title="Review">
                                                    <i class="bi bi-check-circle"></i>
                                                </a>
                                            }
                                            @if (appt.Status == "Scheduled" || appt.Status == "Confirmed")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#cancelModal" data-appt-id="@appt.Id" title="Cancel">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="text-muted mb-2"><i class="bi bi-calendar-x display-4 opacity-25"></i></div>
                                    <h5 class="text-muted fw-bold">No appointments found.</h5>
                                    @if (isPatient)
                                    {
                                        <a asp-controller="Doctor" asp-action="Index" class="btn btn-primary rounded-pill mt-2">Book First Appointment</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white py-3 border-0 d-flex justify-content-center">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link border-0" asp-route-page="@(Model.CurrentPage - 1)" asp-route-searchQuery="@Model.SearchQuery" asp-route-fromDate="@Model.FromDate" asp-route-toDate="@Model.ToDate">Previous</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link border-0 rounded-circle mx-1" asp-route-page="@i" asp-route-searchQuery="@Model.SearchQuery" asp-route-fromDate="@Model.FromDate" asp-route-toDate="@Model.ToDate">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link border-0" asp-route-page="@(Model.CurrentPage + 1)" asp-route-searchQuery="@Model.SearchQuery" asp-route-fromDate="@Model.FromDate" asp-route-toDate="@Model.ToDate">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Cancel Appointment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Cancel" method="post">
                <div class="modal-body">
                    <p class="text-muted mb-3">Are you sure you want to cancel this appointment?</p>
                    <input type="hidden" name="appointmentId" id="cancelApptId" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase">Reason (Optional)</label>
                        <textarea name="reason" class="form-control" rows="3" placeholder="Please let us know why..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Keep It</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4">Yes, Cancel It</button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var cancelModal = document.getElementById('cancelModal');
            if (cancelModal) {
                cancelModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    document.getElementById('cancelApptId').value = button.getAttribute('data-appt-id');
                });
            }
        });
    </script>
}