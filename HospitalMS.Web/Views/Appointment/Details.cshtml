@model HospitalMS.Web.ViewModels.AppointmentDetailViewModel
@{
    ViewData["Title"] = "Appointment Details";
    var statusClass = Model.Status switch
    {
        "Completed" => "bg-success",
        "Cancelled" => "bg-danger",
        "Pending" => "bg-warning text-dark",
        _ => "bg-info"
    };
}
<style>
    @@media print {
        header, .navbar, footer { display: none !important; }
        main { margin-top: 0 !important; padding: 0 !important; min-height: auto !important; }
        .container { max-width: 100% !important; padding: 0 !important; }
        .card { box-shadow: none !important; border: 1px solid #dee2e6 !important; break-inside: avoid; }
        .card-header { background-color: #f8f9fa !important; border-bottom: 1px solid #dee2e6 !important; color: #000 !important; }
        .col-lg-8, .col-lg-4 { width: 100% !important; flex: 0 0 100% !important; max-width: 100% !important; margin-bottom: 1rem !important; }
        .badge { border: 1px solid #000; color: #000 !important; background-color: transparent !important; }
        body { background-color: #fff !important; }
        @@page { margin: 1.5cm; }
    }
</style>

<div class="container py-4">
    <div class="mb-4 d-print-none">
        <a asp-controller="Appointment" asp-action="Index" class="text-decoration-none text-muted">
            <i class="bi bi-arrow-left me-1"></i> Back to Appointments
        </a>
    </div>
    <div class="row g-4 justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold mb-1">Appointment Date</h6>
                        <h3 class="mb-0">@Model.AppointmentDate.ToString("MMMM dd, yyyy")</h3>
                        <div class="text-muted">
                            <i class="bi bi-clock me-1"></i> @Model.StartTime.ToString(@"hh\:mm") - @Model.EndTime.ToString(@"hh\:mm")
                        </div>
                    </div>
                    <div class="text-end">
                        <span class="badge @statusClass px-3 py-2 rounded-pill fs-6">@Model.Status</span>
                    </div>
                </div>
            </div>
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 card-title"><i class="bi bi-file-medical me-2 text-primary"></i> Medical Details</h5>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(Model.Reason))
                    {
                        <div class="mb-4">
                            <label class="text-muted small text-uppercase fw-bold d-block mb-1">Reason for Visit</label>
                            <div class="p-3 bg-light rounded text-dark">@Model.Reason</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Diagnosis))
                    {
                        <div class="mb-4">
                            <label class="text-muted small text-uppercase fw-bold d-block mb-1">Diagnosis</label>
                            <p class="lead mb-0">@Model.Diagnosis</p>
                        </div>
                        <hr class="text-muted opacity-25" />
                    }
                    @if (!string.IsNullOrEmpty(Model.Prescription))
                    {
                        <div class="mb-4">
                            <label class="text-muted small text-uppercase fw-bold d-block mb-1">Prescription</label>
                            <div class="p-3 bg-light border-start border-4 border-success rounded">
                                <pre class="mb-0" style="font-family: inherit; white-space: pre-wrap;">@Model.Prescription</pre>
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="mb-0">
                            <label class="text-muted small text-uppercase fw-bold d-block mb-1">Doctor's Notes</label>
                            <p class="mb-0 text-muted fst-italic">@Model.Notes</p>
                        </div>
                    }
                    @if (string.IsNullOrEmpty(Model.Diagnosis) && string.IsNullOrEmpty(Model.Prescription) && Model.Status != "Scheduled")
                    {
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-journal-x mb-2 d-block h4"></i>
                            No medical records added yet.
                        </div>
                    }
                </div>
            </div>
            @if (User.IsInRole("Doctor") && Model.Status == "Scheduled")
            {
                <div class="card border-primary shadow-sm d-print-none">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0"><i class="bi bi-clipboard-check me-2"></i> Complete Consultation</h5>
                    </div>
                    <div class="card-body p-4">
                        <form asp-action="Complete" method="post">
                            <input type="hidden" name="appointmentId" value="@Model.Id" />
                            <div class="mb-3">
                                <label class="form-label fw-bold">Clinical Diagnosis <span class="text-danger">*</span></label>
                                <textarea name="diagnosis" class="form-control" rows="2" required placeholder="Enter primary diagnosis..."></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Prescription / Treatment <span class="text-danger">*</span></label>
                                <textarea name="prescription" class="form-control" rows="3" required placeholder="List medications and dosage..."></textarea>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold">Internal Notes</label>
                                <textarea name="notes" class="form-control" rows="2" placeholder="Private notes for record..."></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary w-100 py-2">
                                Finalize & Complete
                            </button>
                        </form>
                    </div>
                </div>
            }
            <div class="card border-0 shadow-sm mt-4 text-muted small">
                <div class="card-body p-3 bg-light rounded">
                    <div class="d-flex justify-content-between">
                        <div>
                            <strong>Created By (User ID):</strong> @(string.IsNullOrEmpty(Model.CreatedBy) ? "System" : Model.CreatedBy)
                        </div>
                        <div>
                            <strong>Upated By (User ID):</strong> @(string.IsNullOrEmpty(Model.UpdatedBy) ? "N/A" : Model.UpdatedBy)
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-0">
                    <div class="p-3 border-bottom">
                        <small class="text-muted text-uppercase fw-bold">Patient</small>
                        <div class="d-flex align-items-center mt-2">
                            <div class="avatar bg-light text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                                <i class="bi bi-person h5 mb-0"></i>
                            </div>
                            <div>
                                @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
                                {
                                    <h6 class="mb-0"><a asp-controller="Patient" asp-action="Details" asp-route-id="@Model.PatientId" class="text-decoration-none text-dark">@Model.PatientName</a></h6>
                                    <small class="text-muted d-block mt-1 d-print-none">
                                        <a asp-controller="MedicalRecord" asp-action="Index" asp-route-patientId="@Model.PatientId" class="btn btn-outline-primary btn-sm px-2 py-0 border-0">
                                            <i class="bi bi-file-medical me-1"></i> View Records
                                        </a>
                                    </small>
                                }
                                else
                                {
                                    <h6 class="mb-0">@Model.PatientName</h6>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="p-3">
                        <small class="text-muted text-uppercase fw-bold">Doctor</small>
                        <div class="d-flex align-items-center mt-2">
                            <div class="avatar bg-light text-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                                <i class="bi bi-person-badge h5 mb-0"></i>
                            </div>
                            <div>
                                <h6 class="mb-0">Dr. @Model.DoctorName</h6>
                                <small class="text-muted">@Model.Specialization</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card border-0 shadow-sm d-print-none">
                <div class="card-header bg-white">
                    <h6 class="mb-0 fw-bold">Actions</h6>
                </div>
                <div class="card-body d-grid gap-2">
                    @if (User.IsInRole("Admin") && Model.Status == "Completed")
                    {
                        @if (!Model.HasInvoice)
                        {
                            <a asp-controller="Billing" asp-action="Create" asp-route-appointmentId="@Model.Id" class="btn btn-success">
                                <i class="bi bi-receipt me-2"></i> Generate Invoice
                            </a>
                        }
                        else
                        {
                            if (Model.IsInvoicePaid)
                            {
                                <div class="alert alert-success py-2 mb-2 d-flex align-items-center justify-content-center border-0 small">
                                    <i class="bi bi-check-circle-fill me-2"></i> <strong>Invoice Paid</strong>
                                </div>
                                <a asp-controller="Billing" asp-action="Details" asp-route-id="@Model.InvoiceId" class="btn btn-outline-secondary w-100">
                                    <i class="bi bi-eye me-2"></i> View Invoice
                                </a>
                            }
                            else
                            {
                                <div class="alert alert-warning py-2 mb-2 d-flex align-items-center justify-content-center border-0 small text-dark">
                                    <i class="bi bi-hourglass-split me-2"></i> <strong>Payment Pending</strong>
                                </div>
                                <a asp-controller="Billing" asp-action="Details" asp-route-id="@Model.InvoiceId" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-eye me-2"></i> View Invoice
                                </a>
                            }
                        }
                    }
                    @if (Model.Status != "Completed" && Model.Status != "Cancelled")
                    {
                        <a asp-action="Reschedule" asp-route-id="@Model.Id" class="btn btn-warning">
                            <i class="bi bi-calendar2-week me-2"></i> Reschedule
                        </a>
                        <form asp-action="Cancel" method="post" class="d-grid" onsubmit="return confirm('Are you sure you want to cancel this appointment? This cannot be undone.');">
                            <input type="hidden" name="appointmentId" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="bi bi-x-circle me-2"></i> Cancel Appointment
                            </button>
                        </form>
                    }
                    <a href="javascript:window.print()" class="btn btn-light border">
                        <i class="bi bi-printer me-2"></i> Print Details
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>